# ===========================================
# LitPulse Backend — Production env template
# Copy to .env (locally) or paste the values into Coolify's env-vars UI.
# NEVER commit a populated .env to git.
# ===========================================

# --- Core ---
ENVIRONMENT=production
PORT=8001

# --- Database (MongoDB) ---
# Coolify: point at the Mongo SIBLING SERVICE in the same project network.
# The hostname is whatever you named the Mongo service in Coolify.
MONGO_URL=mongodb://mongo:27017
DB_NAME=litpulse_db

# --- JWT (MUST match Portal Engine's LITPULSE_JWT_SECRET_KEY exactly) ---
# This is the secret that lets Portal Engine validate LitPulse-issued tokens.
# Generate fresh in production; do NOT reuse the dev value committed to git.
JWT_SECRET_KEY=CHANGE_ME_64_CHARS_AND_KEEP_IDENTICAL_TO_PORTAL_ENGINE_LITPULSE_JWT_SECRET_KEY
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# --- Email (SendGrid) ---
SENDGRID_API_KEY=SG.your-sendgrid-key
SENDGRID_FROM_EMAIL=info@scienthesis.ai
SENDGRID_FROM_NAME=LitPulse
ADMIN_EMAIL=info@scienthesis.ai

# --- OpenAI (digests, embeddings, TTS) ---
OPENAI_API_KEY=sk-proj-your-openai-key

# --- NCBI (PubMed harvest) ---
NCBI_API_KEY=your-ncbi-key
CONTACT_EMAIL=info@scienthesis.ai

# --- CORS (comma-separated; add the deployed frontend domains) ---
# Example: https://litportal.scienthesis.ai,https://app.scienthesis.ai
CORS_ORIGINS=https://your-litportal-frontend.example.com,https://your-litpulse-frontend.example.com
